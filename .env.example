# ==============================
# ImportEase - variables locales
# ==============================

# Base de datos
DB_URL=jdbc:mysql://localhost:3306/importease_db?useSSL=false&serverTimezone=America/Lima
DB_USER=importease_app
DB_PASSWORD=importease_dev

# SMTP local recomendado con MailHog/Mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@importease.local
SMTP_STARTTLS=false
SMTP_SSL=false

# URL publica usada para construir el link de recuperacion
APP_PUBLIC_URL=http://localhost:8082/importease

# APIs externas opcionales
PERU_API_TOKEN=
UN_COMTRADE_KEY=
